# Environment configuration for Qwen Inference Engine
# Copy to .env and customize

# Model Path
MODEL_PATH=/mnt/disk/models/Qwen3.5-35B-A3B-GPTQ-Int4

# GPU Configuration
# Use 2,3 for testing (0,1 may be occupied)
CUDA_VISIBLE_DEVICES=2,3
TENSOR_PARALLEL_SIZE=2

# Memory Management
MAX_GPU_MEMORY_GB=48
SAFETY_MARGIN_GB=2.0

# Paged Attention
BLOCK_SIZE=16
NUM_GPU_BLOCKS=120000
NUM_CPU_BLOCKS=10000

# Sequence Limits
MAX_SEQUENCE_LENGTH=250000
MAX_BATCH_SIZE=4

# GPTQ Settings
GPTQ_BITS=4
GPTQ_GROUPSIZE=128

# Logging
LOG_LEVEL=INFO
LOG_MEMORY_USAGE=true